# Local development
# Setup: cp .env.development .env && php artisan key:generate

# Application
APP_NAME=NewsPortal
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# MySQL (Docker: docker-compose.yml → localhost:3307)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3307
DB_DATABASE=news_portal
DB_USERNAME=news_user
DB_PASSWORD=news_password

# Faster local dev caching (avoids DB lock contention under load)
CACHE_STORE=file
